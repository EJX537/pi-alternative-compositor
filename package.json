{
    "name": "pi-alternative-compositor",
    "version": "1.0.0",
    "description": "[Experimental] Scrollable chat viewport compositor with mouse selection and keyboard scrolling for pi.",
    "license": "MIT",
    "author": "",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ejx537/pi-alternative-compositor"
    },
    "scripts": {
        "test": "vitest run --config tests/vitest.config.ts",
        "test:watch": "vitest --config tests/vitest.config.ts",
        "typecheck": "tsc --noEmit"
    },
    "files": [
        "src/**/*.ts",
        "docs/**",
        "README.md"
    ],
    "keywords": [
        "pi-package",
        "pi",
        "coding-agent",
        "extension",
        "compositor",
        "scroll",
        "tui",
        "pi-extension"
    ],
    "peerDependencies": {
        "@earendil-works/pi-coding-agent": ">=0.78.0",
        "@earendil-works/pi-tui": ">=0.78.0"
    },
    "devDependencies": {
        "@earendil-works/pi-coding-agent": ">=0.78.0",
        "@earendil-works/pi-tui": ">=0.78.0",
        "@types/node": "^22.0.0",
        "typescript": "^5.0.0",
        "vitest": "^4.1.10"
    },
    "pi": {
        "extensions": [
            "./src/index.ts"
        ]
    }
}
